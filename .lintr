linters: linters_with_defaults(
        quotes_linter = NULL,
        return_linter = NULL,
        indentation_linter(hanging_indent_style = "never"),
        object_length_linter(length = 50L),
        line_length_linter(100),
        object_name_linter(
            styles = c("snake_case", "symbols"),
            regexes = c("^as\\.[a-z]*$", "^is\\.[a-z]*$")
        )
    )
